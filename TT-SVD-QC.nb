  3.991888341922284*^9}},ExpressionUUID->"e754741c-f86b-48df-9575-\
3ea16c67aff4"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"M1", "=", 
   RowBox[{"ArrayReshape", "[", 
    RowBox[{"Core1", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"dims1", "[", 
         RowBox[{"[", "1", "]"}], "]"}], " ", 
        RowBox[{"dims1", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ",", 
       RowBox[{"dims1", "[", 
        RowBox[{"[", "3", "]"}], "]"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"M1", "//", "MatrixForm"}]}], "Input",
 CellChangeTimes->{{3.991809136389187*^9, 3.9918091944451237`*^9}, 
   3.9918095540729437`*^9, {3.9918098770683804`*^9, 3.991809879790724*^9}, {
