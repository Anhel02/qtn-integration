 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"U1", ",", "S1", ",", "V1"}], "}"}], "=", 
   RowBox[{"SingularValueDecomposition", "[", "B1", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"U1", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"S1", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Transpose", "[", "V1", "]"}], "//", "MatrixForm"}]}], "Input",
