Cell[CellGroupData[{

Cell["Reshape", "Subsection",
 CellChangeTimes->{{3.9918059263697653`*^9, 
  3.991805942829954*^9}},ExpressionUUID->"b48570d1-a329-4c5e-8216-\
3d2b3d74e65b"],

Cell["\<\
First we ought to reshape the order-3 tensor into a matrix, this can be done \
via unfolding. In this case we reshape the 2x2x2 tensor into a 2x4 matrix. \
This separates the first dimension from the rest, preparing the data for our \
first Singular Value Decomposition.\
\>", "Text",
 CellChangeTimes->{{3.99180594726151*^9, 3.9918059776068974`*^9}, {
  3.9918060783559847`*^9, 
  3.991806081033*^9}},ExpressionUUID->"f0927f03-81c6-4a32-92ec-c2b0673837af"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"B1", "=", 
   RowBox[{"ArrayReshape", "[", 
    RowBox[{"A", ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "4"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"B1", "//", "MatrixForm"}]}], "Input",
 CellChangeTimes->{{3.991806253689533*^9, 3.9918062571232452`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"9dffc925-1027-4e1d-8295-8a80780a4dfb"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {"1.`", "2.`", "3.`", "4.`"},
     {"5.`", "6.`", "7.`", "8.`"}
    },
    GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[0.7]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{
  3.991806908518186*^9, 3.991807805802227*^9, 3.991811936292676*^9, 
   3.9918773430057993`*^9, 3.9918781130508957`*^9, 3.991888006407239*^9, 
   3.991888446581153*^9, {3.9924893863244667`*^9, 3.992489412684628*^9}},
 CellLabel->
  "Out[8]//MatrixForm=",ExpressionUUID->"37160848-401f-480a-8bb0-\
4d8d948e3801"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["First SVD and Core 1", "Subsection",
 CellChangeTimes->{{3.991806105081625*^9, 
  3.991806118259677*^9}},ExpressionUUID->"9001c48e-bfcd-481d-a825-\
25dc080816bd"],

Cell["\<\
Next, we perform the Singular Value Decomposition (SVD) on our unfolded \
matrix B1:\
\>", "Text",
 CellChangeTimes->{{3.9918061238362007`*^9, 3.991806130945271*^9}, {
  3.991806376667592*^9, 
  3.991806393048778*^9}},ExpressionUUID->"3e7c97bf-0204-4365-9c35-\
f003ba829603"],

