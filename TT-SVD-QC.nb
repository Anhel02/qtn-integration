 TagBox[
  RowBox[{"(", "\[NoBreak]", 
   TagBox[GridBox[{
      {"1.`"},
      {"2.`"},
      {"3.`"},
      {"4.`"},
      {"5.`"},
      {"6.`"},
      {"7.`"},
      {"8.`"}
     },
     GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
     GridBoxSpacings->{"Columns" -> {
         Offset[0.27999999999999997`], {
          Offset[0.5599999999999999]}, 
         Offset[0.27999999999999997`]}, "Rows" -> {
         Offset[0.2], {
          Offset[0.4]}, 
         Offset[0.2]}}],
    Column], "\[NoBreak]", ")"}],
  Function[BoxForm`e$, 
   MatrixForm[BoxForm`e$]]]], "Output",
 CellChangeTimes->{3.99180828237282*^9, 3.991811935667017*^9, 
  3.991877335919105*^9, 3.9918781128378277`*^9, 3.991888006225892*^9, 
  3.9918884463743563`*^9, 3.992489376619007*^9, 3.9924894124205093`*^9},
