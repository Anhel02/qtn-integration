Cell["\<\
Now we apply the gates, W3 is already a 8x8 matrix, but we will need to do a \
tensor product of W2 and the 2x2 identity and twice with W1:\
\>", "Text",
 CellChangeTimes->{{3.991811012463448*^9, 
  3.991811083544986*^9}},ExpressionUUID->"2bfa94ce-f5e6-4c0f-b3ef-\
dc537e1bd33b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"qc", "=", 
   RowBox[{
    RowBox[{"KroneckerProduct", "[", 
     RowBox[{"W1", ",", 
      RowBox[{"KroneckerProduct", "[", 
       RowBox[{
        RowBox[{"IdentityMatrix", "[", "2", "]"}], ",", 
        RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}]}], "]"}], ".", 
    RowBox[{"KroneckerProduct", "[", 
     RowBox[{"W2", ",", 
      RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "]"}], ".", "W3"}]}], 
  ";"}], "\n", 
 RowBox[{"qc", "//", "MatrixForm"}]}], "Input",
 CellChangeTimes->{{3.991811087472596*^9, 3.991811142273878*^9}, {
  3.9918111893516207`*^9, 3.991811208833387*^9}, {3.9918115393337917`*^9, 
