Cell["\<\
And we can here get the first bond dimension (n1) for the next algorithm:\
\>", "Text",
 CellChangeTimes->{{3.991877259783298*^9, 
  3.9918772818515797`*^9}},ExpressionUUID->"739561bc-8cf3-446a-9521-\
5d2a8d2ec849"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"n1", "=", 
  RowBox[{"Count", "[", 
   RowBox[{
    RowBox[{"Diagonal", "[", "S1", "]"}], ",", 
    RowBox[{"x_", "/;", 
