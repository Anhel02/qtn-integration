 CellLabel->"Out[35]=",ExpressionUUID->"6181081f-b4fb-43e8-b62b-a77667638d9f"]
}, Open  ]],

Cell["\<\
The reshape can be done by multiplying the first two dimensions to get the \
rows and let the last dimension as the columns, so the unfolding matrix has \
all the elements of the original tensor:\
\>", "Text",
 CellChangeTimes->{{3.99187748374673*^9, 3.991877499853744*^9}, {
  3.9918875890524797`*^9, 3.9918877600355787`*^9}, {3.991887797622781*^9, 
