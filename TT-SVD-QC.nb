Cell[CellGroupData[{

Cell["Verification", "Subsection",
 CellChangeTimes->{{3.9918103649338827`*^9, 
  3.9918103665319843`*^9}},ExpressionUUID->"0a4e8853-368e-4476-a1ee-\
682d34978fd1"],

Cell["We create the initial state |000>:", "Text",
 CellChangeTimes->{{3.991810991711936*^9, 
  3.9918109972608643`*^9}},ExpressionUUID->"e171c2e1-1c52-47d3-8a36-\
4e99577b9394"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ket0", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", "1", "}"}], ",", 
     RowBox[{"{", "0", "}"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Psi0", "=", 
   RowBox[{"KroneckerProduct", "[", 
    RowBox[{"ket0", ",", 
     RowBox[{"KroneckerProduct", "[", 
      RowBox[{"ket0", ",", "ket0"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Psi0", "//", "MatrixForm"}]}], "Input",
 CellChangeTimes->{{3.9918103681010113`*^9, 3.991810379935115*^9}, {
