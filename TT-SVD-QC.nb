Cell["\<\
We can verify that the tensor has the correct 2x2x2 dimensions:\
\>", "Text",
 CellChangeTimes->{{3.991807775923376*^9, 3.9918077827293167`*^9}, {
  3.991808583786422*^9, 
  3.9918085873028812`*^9}},ExpressionUUID->"35b8b751-efa4-4b3f-992e-\
