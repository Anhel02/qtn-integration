4b3e4fee0102"],

Cell["\<\
For this example, we start with an array from 1 to 8 that will later become \
our 2x2x2 tensor:\
\>", "Text",
 CellChangeTimes->{{3.9918082111264477`*^9, 3.991808251214019*^9}, {
  3.991808506899239*^9, 
  3.9918085264268913`*^9}},ExpressionUUID->"f145e0b7-8895-4300-9693-\
fa14f69ab9e3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p", " ", "=", " ", 
   RowBox[{"N", "[", 
    RowBox[{"{", 
     RowBox[{
     "1", ",", "2", ",", "3", ",", "4", ",", "5", ",", "6", ",", "7", ",", 
      "8"}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"p", "//", "MatrixForm"}]}], "Input",
 CellChangeTimes->{{3.9918082278098173`*^9, 3.991808247017736*^9}, {
  3.9918082787451344`*^9, 3.9918082819915867`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"3ad1f33f-0d49-4efd-80ec-bdf0349dcd83"],

